# =========================================================================
#                    DAWGS WEB - ARCHIVO DE CONFIGURACIÓN (.env)
# =========================================================================
# Copia este archivo como ".env" en la raíz del proyecto y coloca tus credenciales reales.
# 
# NOTA DE SEGURIDAD:
# - Las variables del FRONTEND expuestas en el cliente deben usar el prefijo VITE_ o NEXT_PUBLIC_.
# - Las variables del BACKEND (Private Key, Merchant ID) NUNCA se inyectan en el cliente y
#   deben mantenerse seguras solo en el entorno del servidor.
# =========================================================================

# -------------------------------------------------------------------------
# 1. FRONTEND: CONFIGURACIÓN DE KUSHKI (CLIENT-SIDE)
# -------------------------------------------------------------------------
# VITE_KUSHKI_PUBLIC_KEY: Tu clave pública (Public Merchant ID) obtenida de la consola de Kushki.
# Dónde colocarla:
# - Localmente: Archivo ".env" o ".env.local"
# - Vercel/Railway/Render: Configurar en las variables de entorno de la app (Build variables).
VITE_KUSHKI_PUBLIC_KEY=b4c2b998a6984e1b8b6038f6fa9bca9a
NEXT_PUBLIC_KUSHKI_PUBLIC_KEY=b4c2b998a6984e1b8b6038f6fa9bca9a

# NEXT_PUBLIC_SITE_URL: URL raíz del frontend para redirecciones y CORS.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------------------------------------
# CLOUDFLARE TURNSTILE - CAPTCHA / VERIFICACION HUMANA
# -------------------------------------------------------------------------
# Crea 2 widgets en Cloudflare Turnstile:
# - Visible/Managed: compra de entrada y admin login.
# - Invisible: recuperacion de entrada por Gmail.
NEXT_PUBLIC_TURNSTILE_SITE_KEY_VISIBLE=
TURNSTILE_SECRET_KEY_VISIBLE=
NEXT_PUBLIC_TURNSTILE_SITE_KEY_INVISIBLE=
TURNSTILE_SECRET_KEY_INVISIBLE=
# Opcional: fuerza Turnstile durante npm run dev. Por defecto se omite en desarrollo.
NEXT_PUBLIC_TURNSTILE_IN_DEVELOPMENT=false
TURNSTILE_IN_DEVELOPMENT=false

# -------------------------------------------------------------------------
# ANALISIS VISUAL OPCIONAL DE COMPROBANTES - SOLO SERVIDOR
# -------------------------------------------------------------------------
# Opcional. Sin esta clave se usa OCR, calidad de imagen y perfiles locales.
OPENAI_API_KEY=
# Modelo de vision complementario con Structured Outputs.
OPENAI_RECEIPT_MODEL=gpt-5.5
# Umbral del analisis visual entre 0.50 y 0.95. Recomendado: 0.72.
RECEIPT_AI_MIN_CONFIDENCE=0.72

# -------------------------------------------------------------------------
# GMAIL API - ENTREGA DE ENTRADAS
# -------------------------------------------------------------------------
# Canal principal para enviar el PDF de la entrada. WhatsApp/Baileys solo
# confirma la compra y dirige al usuario a revisar Gmail o Recuperar entrada.
GMAIL_USER=soporte.dawgs@gmail.com
GMAIL_FROM=DAWGS <soporte.dawgs@gmail.com>
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_DAILY_LIMIT=100

# Alternativa mas simple: SMTP de Gmail con contrasena de aplicacion.
# Si Gmail API no esta configurado, el sistema usa SMTP automaticamente.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=DAWGS <tu-correo@gmail.com>

# -------------------------------------------------------------------------
# RECUPERACION DE ENTRADAS - SOLO EVENTO ACTIVO
# -------------------------------------------------------------------------
# Debe coincidir con el slug/id publico usado por tickets y QRs.
CURRENT_EVENT_ID=trap-loud
# Opcional: reemplaza la lista de artistas leida desde data/events.json.
CURRENT_EVENT_ARTIST=
# Secreto exclusivo para JWT temporales de recuperacion (minimo 32 bytes).
TICKET_RECOVERY_SECRET=change-this-with-a-random-32-byte-secret

# -------------------------------------------------------------------------
# 2. BACKEND: CONFIGURACIÓN DE KUSHKI (SERVER-SIDE)
# -------------------------------------------------------------------------
# KUSHKI_ENV: Determina si se conecta a sandbox ("sandbox" o "uat") o producción ("production").
KUSHKI_ENV=sandbox

# KUSHKI_PRIVATE_KEY: Tu clave privada (Private Merchant ID) provista por Kushki.
KUSHKI_PRIVATE_KEY=90af8c7b6d5e4c3b2a1a0f9e8d7c6b5a

# KUSHKI_MERCHANT_ID: ID del comercio o identificador único provisto por Kushki.
KUSHKI_MERCHANT_ID=10000003028301290382

# KUSHKI_WEBHOOK_SIGNATURE: Firma de webhook secreta de Kushki.
KUSHKI_WEBHOOK_SIGNATURE=signature_secret_obtained_from_kushki_console

# Opcional: Anulación manual de URL base para Kushki.
KUSHKI_API_BASE=https://api-uat.kushkipagos.com
NEXT_PUBLIC_KUSHKI_API_BASE=https://api-uat.kushkipagos.com

# -------------------------------------------------------------------------
# WHATSAPP — BAILEYS (WHATSAPP WEB, SIN COSTOS DE API)
# -------------------------------------------------------------------------
# Baileys usa el protocolo Web de WhatsApp (gratuito). Requiere escanear un QR
# con tu teléfono la primera vez. La sesión se persiste en wa_session/.
# Para Railway, monta un volumen persistente en /app/wa_session:
#   railway volumes add --mountPath /app/wa_session
#
# Habilita el worker Baileys en el backend de Express/Railway:
WHATSAPP_ENABLED=true
BACKEND_URL=http://localhost:4000
BAILEYS_SESSION_DIR=wa_session
BAILEYS_LOG_LEVEL=info
CONNECTION_READY_DELAY_MS=15000
# Delays antispam entre mensajes (20-40s por defecto):
WHATSAPP_MIN_DELAY_MS=20000
WHATSAPP_MAX_DELAY_MS=40000
# API key para endpoints protegidos de WhatsApp ( /api/whatsapp/logout , ...)
# Déjala vacía solo en desarrollo local.
WHATSAPP_API_KEY=change-me-in-production

# META WHATSAPP CLOUD API (FALLBACK / CANAL ALTERNATIVO)
# Se usa solo si Baileys no está disponible o como respaldo.

# -------------------------------------------------------------------------
# 3. BASE DE DATOS Y SERVICIOS COMPLEMENTARIOS
# -------------------------------------------------------------------------
# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Firebase (Fallback temporal)
FIREBASE_PROJECT_ID=dawgs-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@dawgs.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -------------------------------------------------------------------------
# 4. SEGURIDAD GENERAL Y SESIÓN DE STAFF
# -------------------------------------------------------------------------
# Claves criptográficas (Generar con: openssl rand -base64 32)
DATA_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
JWT_SECRET=staff-jwt-secret-min-32-bytes-long-string-key
QR_HASH_SECRET=qr-hash-secret-value-for-deterministic-validation

# Credenciales Staff / Admin (base64: Next expande $ en hashes bcrypt crudos)
STAFF_PASSWORD_HASH_B64=JDJiJDEyJGlqNUFZYVRCSndsUGF4ZTRKdUs0aXUuUjN3SW1SclY2Tk9xWjBRNjVrc1BXamI2RzFQajZh
ADMIN_PASSWORD_HASH_B64=JDJiJDEyJElSUExxUU1hUFNidUE4Q3d6ZnlnNE9TRXMvREVTbVBuN3h6aEZXM0Q0THhvUDRzQ1VmbW9t

# -------------------------------------------------------------------------
# 5. CONFIGURACIÓN DEL SERVIDOR EXPRESS (BACKEND)
# -------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PORT=4000
